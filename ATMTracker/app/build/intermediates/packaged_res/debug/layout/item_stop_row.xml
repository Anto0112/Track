<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:gravity="center_vertical"
    android:paddingHorizontal="16dp" android:paddingVertical="12dp"
    android:background="?attr/selectableItemBackground">
    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical">
        <TextView android:id="@+id/tv_stop_desc" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:textSize="14sp"
            android:textStyle="bold" android:maxLines="2" android:ellipsize="end"/>
        <TextView android:id="@+id/tv_stop_code" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textSize="11sp"
            android:fontFamily="monospace" android:alpha="0.6"/>
    </LinearLayout>
    <ProgressBar android:id="@+id/progress_wait"
        android:layout_width="24dp" android:layout_height="24dp" android:visibility="gone"/>
    <TextView android:id="@+id/tv_stop_wait"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textSize="16sp" android:textStyle="bold"
        android:layout_marginStart="8dp" android:minWidth="48dp" android:gravity="end"/>
</LinearLayout>
