<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <org.osmdroid.views.MapView
        android:id="@+id/map"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:focusable="true"/>

    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone"/>

    <!-- Hint tocca mappa -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="#CC000000"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:text="Tocca sulla mappa per cercare fermate vicine"/>

    <!-- FAB preferiti: in alto a destra, poco invasivo, bianco con cuore blu -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_favorites"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end|top"
        android:layout_margin="12dp"
        android:layout_marginTop="16dp"
        android:contentDescription="Fermate preferite"
        android:src="@drawable/ic_heart_outline"
        app:fabSize="mini"
        app:backgroundTint="#FFFFFF"
        app:tint="#0266ad"/>

    <!-- FAB posizione attuale: in basso a destra -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_locate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:contentDescription="Posizione attuale"
        android:src="@android:drawable/ic_menu_mylocation"
        app:backgroundTint="#0266ad"
        app:tint="#FFFFFF"/>

</FrameLayout>